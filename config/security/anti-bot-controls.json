{
  "version": "2026-02-26",
  "rateLimits": [
    {
      "scope": "auth:otp:request",
      "windowSec": 900,
      "max": 5
    },
    {
      "scope": "tickets:reserve",
      "windowSec": 60,
      "max": 20
    },
    {
      "scope": "marketplace:purchase",
      "windowSec": 60,
      "max": 10
    }
  ],
  "captcha": {
    "requiredFor": [
      "tickets:purchase",
      "marketplace:purchase"
    ],
    "provider": "hcaptcha"
  },
  "purchaseThrottle": {
    "perUserPerEventPerMinute": 4,
    "perIpPerMinute": 30
  }
}
