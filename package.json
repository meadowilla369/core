{
  "name": "ticket-platform-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Ticket platform monorepo skeleton (FE, BE, contracts, infra)",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "format:write": "prettier . --write",
    "prepare": "husky",
    "contracts:test": "cd contracts && forge test --offline"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
